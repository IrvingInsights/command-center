{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://peakhinge.local/schemas/edit_request.schema.json",
  "title": "EditRequest",
  "type": "object",
  "required": ["request_text", "subassembly", "timestamp_utc"],
  "properties": {
    "request_text": { "type": "string", "minLength": 1 },
    "subassembly": { "type": "string", "const": "pipe_pivot" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "user_id": { "type": "string" }
  },
  "additionalProperties": false
}
